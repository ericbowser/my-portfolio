{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vite Dev Server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bhttps?://localhost:([0-9]+)\\b",
        "uriFormat": "http://localhost:%s"
      },
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
