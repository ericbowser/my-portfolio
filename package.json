{
  "name": "my-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "jest",
    "test:watch": "jest --watch",
    "tail:watch": "npx tailwindcss -i ./src/styles/input.css -o ./src/styles/output.css --watch",
    "tail": "npx tailwindcss -i ./src/styles/input.css -o ./src/styles/output.css",
    "build:docker": "docker build -t my-portfolio .",
    "run": "docker run -p 31666:31666 my-portfolio",
    "clean": "rm -rf node_modules package-lock.json && npm install"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-jest": "^30.4.0",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "tailwindcss": "^3.4.17",
    "vite": "^7.3.3"
  },
  "overrides": {
    "esbuild": ">=0.28.1",
    "js-yaml": ">=4.1.2"
  }
}
